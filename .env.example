# Copy this file to .env for local dev with `vercel dev`
# In production, set these in Vercel dashboard → Settings → Environment Variables

# ── Required: pick ONE of the two API key options ────────────────────────────

# Option A — DeepSeek (cheap, recommended for testing)
# Get your key at: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Option B — OpenAI
# Get your key at: https://platform.openai.com
# OPENAI_API_KEY=sk-your-openai-key-here

# ── Optional overrides ────────────────────────────────────────────────────────

# Override the model (defaults: deepseek-chat or gpt-4o-mini)
# AI_MODEL=deepseek-chat

# Override the API base URL (useful for other OpenAI-compatible providers)
# API_BASE_URL=https://api.deepseek.com
